# ============================================
# REQUIRED - Neon PostgreSQL
# Get from: https://neon.tech (free)
# Use the "pooled" connection string for DATABASE_URL
# Use the "direct" connection string for DIRECT_URL
# ============================================
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ============================================
# REQUIRED - Auth
# JWT_SECRET: any long random string
# ============================================
JWT_SECRET="your-super-secret-jwt-key"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# ============================================
# REQUIRED - Admin credentials (auto-seeded on build)
# ============================================
ADMIN_EMAIL="admin@bypass.ai"
ADMIN_PASSWORD="change-this-password"

# ============================================
# REQUIRED - Email sending
# Get from: https://resend.com (free tier available)
# ============================================
RESEND_API_KEY="re_xxxxxxxxxxxx"

# ============================================
# OPTIONAL - PayPal payments
# ============================================
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
